{
  "name": "tinker-studio",
  "version": "26.2.0",
  "description": "Tinker Studio — a modern molecular modeling GUI for Tinker",
  "main": "./out/main/index.js",
  "author": "Jay Ponder Lab",
  "license": "Apache-2.0",
  "type": "commonjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac --publish never",
    "dist:win": "electron-vite build && electron-builder --win --publish never",
    "dist:linux": "electron-vite build && electron-builder --linux --publish never"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^3.2.6"
  }
}
